# ── server ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
CORS_ORIGIN=*

# ── python microservices ─────────────────────────────────────────
CONTEXT_URL=http://context:5001
PAYLOAD_GEN_URL=http://payload-gen:5002
FUZZER_URL=http://fuzzer:5003

# ── redis ────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://rs:rs@postgres:5432/redsentinel

# ── auth ─────────────────────────────────────────────────────────
API_KEY_SECRET=change-me-before-deploy

# JWT Authentication
# core/.env
JWT_SECRET=your-secret-key
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...
# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:8080

# ── scan defaults ────────────────────────────────────────────────
DEFAULT_SCAN_DEPTH=3
DEFAULT_MAX_PAYLOADS=50
DEFAULT_TIMEOUT_MS=60000

# ── http client ──────────────────────────────────────────────────
HTTP_TIMEOUT=30000
