<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Security Report — {{target}}</title>
  <style>
    :root {
      --bg: #0d0d0d;
      --surface: #141414;
      --surface2: #1a1a1a;
      --border: #2a2a2a;
      --text: #e0e0e0;
      --text-soft: #b0b0b0;
      --muted: #888;
      --red: #ff4455;
      --orange: #ffaa00;
      --green: #88cc00;
      --cyan: #44ccff;
      --blue: #4488ff;
      --accent: #ff4455;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      padding: 2rem 3rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    /* ── Header ────────────────────── */
    .header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 0.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 2px solid var(--accent);
    }

    .header h1 { color: var(--accent); font-size: 1.8rem; font-weight: 700; }
    .header .logo {
      width: 2rem;
      height: 2rem;
      object-fit: contain;
      display: block;
    }
    .subtitle { color: var(--muted); margin-bottom: 2rem; font-size: 0.9rem; }

    /* ── Risk banner ───────────────── */
    .risk-banner {
      border-radius: 10px;
      padding: 1.5rem 2rem;
      margin-bottom: 2rem;
      border: 1px solid var(--border);
    }

    .risk-banner.risk-critical { background: linear-gradient(135deg, #2a0a0e, #1a0a0e); border-color: #ff445566; }
    .risk-banner.risk-high     { background: linear-gradient(135deg, #2a150a, #1a100a); border-color: #ff664466; }
    .risk-banner.risk-medium   { background: linear-gradient(135deg, #2a200a, #1a170a); border-color: #ffaa0066; }
    .risk-banner.risk-low      { background: linear-gradient(135deg, #0a2a0e, #0a1a0e); border-color: #88cc0066; }
    .risk-banner.risk-none     { background: linear-gradient(135deg, #0a1a0e, #0a1a0a); border-color: #88cc0066; }

    .risk-banner .risk-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
      margin-bottom: 0.3rem;
    }

    .risk-banner .risk-level {
      font-size: 1.6rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .risk-banner.risk-critical .risk-level { color: var(--red); }
    .risk-banner.risk-high .risk-level     { color: #ff6644; }
    .risk-banner.risk-medium .risk-level   { color: var(--orange); }
    .risk-banner.risk-low .risk-level      { color: var(--green); }
    .risk-banner.risk-none .risk-level     { color: var(--green); }

    .risk-banner .risk-desc {
      color: var(--text-soft);
      font-size: 1rem;
      line-height: 1.6;
    }

    /* ── Scan details ──────────────── */
    .scan-details {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .detail-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem 1.2rem;
    }

    .detail-card .label {
      color: var(--muted);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .detail-card .value {
      font-size: 1.1rem;
      font-weight: 600;
      margin-top: 0.2rem;
      word-break: break-all;
    }

    /* ── Counts bar ────────────────── */
    .counts-bar {
      display: flex;
      gap: 1.5rem;
      margin-bottom: 2rem;
      flex-wrap: wrap;
    }

    .count-chip {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.7rem 1.3rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .count-chip .num { font-size: 1.4rem; font-weight: 700; }
    .count-chip.critical .num { color: var(--red); }
    .count-chip.high .num     { color: #ff6644; }
    .count-chip.medium .num   { color: var(--orange); }
    .count-chip.low .num      { color: var(--green); }

    /* ── Section titles ────────────── */
    h2 {
      color: var(--cyan);
      font-size: 1.3rem;
      margin: 2.5rem 0 0.8rem;
      padding-bottom: 0.4rem;
      border-bottom: 1px solid var(--border);
    }

    h2 .count-tag {
      font-size: 0.85rem;
      color: var(--muted);
      font-weight: 400;
    }

    /* ── Affected pages ────────────── */
    .affected-pages {
      list-style: none;
      margin-bottom: 1rem;
    }

    .affected-pages li {
      padding: 0.4rem 0;
      font-size: 0.92rem;
      color: var(--blue);
      word-break: break-all;
    }

    .affected-pages li::before {
      content: "⚠ ";
      color: var(--orange);
    }

    /* ── Summary table ─────────────── */
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
    }

    th {
      background: var(--surface);
      color: var(--muted);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 0.8rem 1rem;
      text-align: left;
      border-bottom: 2px solid var(--border);
    }

    td {
      padding: 0.7rem 1rem;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }

    tr:hover td { background: rgba(255,68,85,0.03); }

    .sev-critical { color: var(--red); font-weight: 700; }
    .sev-high     { color: #ff6644; font-weight: 700; }
    .sev-medium   { color: var(--orange); font-weight: 600; }
    .sev-low      { color: var(--green); }

    .code-cell {
      font-family: 'Fira Code', 'Consolas', monospace;
      font-size: 0.8rem;
      background: var(--surface2);
      padding: 0.3rem 0.6rem;
      border-radius: 4px;
      word-break: break-all;
      display: inline-block;
      max-width: 350px;
    }

    .badge {
      display: inline-block;
      padding: 0.15rem 0.6rem;
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .badge-yes { background: rgba(136,204,0,0.15); color: var(--green); }
    .badge-no  { background: rgba(255,68,85,0.1); color: #ff6666; }

    /* ── Vuln cards ────────────────── */
    .vuln-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 4px solid var(--red);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 1.2rem;
    }

    .vuln-card.severity-high    { border-left-color: #ff6644; }
    .vuln-card.severity-medium  { border-left-color: var(--orange); }
    .vuln-card.severity-low     { border-left-color: var(--green); }

    .vuln-card-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1rem;
    }

    .vuln-card-head h3 { font-size: 1.05rem; color: var(--text); }
    .vuln-card-head .sev-tag {
      padding: 0.2rem 0.8rem;
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .sev-tag.sev-critical { background: rgba(255,68,85,0.15); color: var(--red); }
    .sev-tag.sev-high     { background: rgba(255,102,68,0.15); color: #ff6644; }
    .sev-tag.sev-medium   { background: rgba(255,170,0,0.15); color: var(--orange); }
    .sev-tag.sev-low      { background: rgba(136,204,0,0.15); color: var(--green); }

    .vuln-section {
      margin-bottom: 1rem;
    }

    .vuln-section-title {
      font-size: 0.75rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.3rem;
    }

    .vuln-section p {
      color: var(--text-soft);
      font-size: 0.92rem;
      line-height: 1.6;
    }

    .vuln-meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem 2rem;
      font-size: 0.88rem;
      margin-bottom: 1rem;
    }

    .vuln-meta-item {
      display: flex;
      gap: 0.5rem;
    }

    .vuln-meta-item .meta-label { color: var(--muted); min-width: 100px; }
    .vuln-meta-item .meta-value { color: var(--text); word-break: break-all; }

    .fix-box {
      background: rgba(136,204,0,0.05);
      border: 1px solid rgba(136,204,0,0.15);
      border-radius: 6px;
      padding: 1rem;
    }

    .fix-box p {
      color: var(--green) !important;
      font-size: 0.88rem !important;
    }

    /* ── No vulns ──────────────────── */
    .no-vulns {
      text-align: center;
      padding: 3rem 1rem;
    }

    .no-vulns .checkmark { font-size: 3rem; margin-bottom: 1rem; }
    .no-vulns h3 { color: var(--green); font-size: 1.3rem; margin-bottom: 0.5rem; }
    .no-vulns p { color: var(--muted); }

    /* ── Footer ────────────────────── */
    .footer {
      margin-top: 3rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
      color: var(--muted);
      font-size: 0.8rem;
      text-align: center;
    }
  </style>
</head>
<body>

  <!-- Header -->
  <div class="header">
    {{#if logoSrc}}<img class="logo" src="{{logoSrc}}" alt="RedSentinel logo"/>{{/if}}
    <h1>RedSentinel Security Report</h1>
  </div>
  <p class="subtitle">Automated security scan results for <strong>{{target}}</strong></p>

  <!-- Risk Banner -->
  <div class="risk-banner risk-{{riskClass}}">
    <div class="risk-label">Overall Risk Level</div>
    <div class="risk-level">{{riskLevel}}</div>
    <div class="risk-desc">{{riskSummary}}</div>
  </div>

  <!-- Scan Details -->
  <div class="scan-details">
    <div class="detail-card">
      <div class="label">Website Scanned</div>
      <div class="value" style="font-size:0.9rem;">{{target}}</div>
    </div>
    <div class="detail-card">
      <div class="label">Scan Completed</div>
      <div class="value" style="font-size:0.9rem;">{{completedAt}}</div>
    </div>
    <div class="detail-card">
      <div class="label">Scan Duration</div>
      <div class="value">{{duration}}</div>
    </div>
    <div class="detail-card">
      <div class="label">Issues Found</div>
      <div class="value">{{vulnCount}}</div>
    </div>
  </div>

  <!-- Severity Counts -->
  <div class="counts-bar">
    <div class="count-chip critical">
      <span class="num">{{counts.critical}}</span><span>Critical</span>
    </div>
    <div class="count-chip high">
      <span class="num">{{counts.high}}</span><span>High</span>
    </div>
    <div class="count-chip medium">
      <span class="num">{{counts.medium}}</span><span>Medium</span>
    </div>
    <div class="count-chip low">
      <span class="num">{{counts.low}}</span><span>Low</span>
    </div>
  </div>

  {{#if hasVulns}}

  <!-- Affected Pages -->
  <h2>Affected Pages <span class="count-tag">({{affectedPageCount}})</span></h2>
  <p style="color:var(--text-soft); font-size:0.9rem; margin-bottom:0.8rem;">
    These pages on your website were found to have security issues:
  </p>
  <ul class="affected-pages">
    {{#each affectedPages}}
    <li>{{this}}</li>
    {{/each}}
  </ul>

  <!-- Quick Summary Table -->
  <h2>Summary of Issues</h2>
  <p style="color:var(--text-soft); font-size:0.9rem; margin-bottom:1rem;">
    Each row is a confirmed security issue. "Confirmed" in the last column means malicious code actually executed in a test browser.
  </p>
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Page</th>
        <th>Input Field</th>
        <th>Risk Level</th>
        <th>Code Ran in Browser?</th>
      </tr>
    </thead>
    <tbody>
      {{#each vulns}}
      <tr>
        <td>{{this.index}}</td>
        <td style="font-size:0.82rem; word-break:break-all; max-width:280px;">{{this.url}}</td>
        <td><strong>{{this.param}}</strong></td>
        <td class="sev-{{this.severityClass}}">{{this.severity}}</td>
        <td>
          {{#if this.confirmedDangerous}}
            <span class="badge badge-yes">Yes — Confirmed</span>
          {{else if this.executed}}
            <span class="badge badge-yes">Yes</span>
          {{else}}
            <span class="badge badge-no">Not confirmed</span>
          {{/if}}
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <!-- Detailed Findings -->
  <h2>Detailed Findings</h2>
  <p style="color:var(--text-soft); font-size:0.9rem; margin-bottom:1.5rem;">
    Below is a detailed breakdown of each issue, explaining what was found and how to fix it.
  </p>

  {{#each vulns}}
  <div class="vuln-card severity-{{this.severityClass}}">
    <div class="vuln-card-head">
      <h3>Issue #{{this.index}} — {{this.typeFriendly}}</h3>
      <span class="sev-tag sev-{{this.severityClass}}">{{this.severity}}</span>
    </div>

    <!-- What is this? -->
    <div class="vuln-section">
      <div class="vuln-section-title">What is this?</div>
      <p>{{this.typeExplanation}}</p>
    </div>

    <!-- What we found -->
    <div class="vuln-section">
      <div class="vuln-section-title">What we found</div>
      <p>{{this.whatHappened}}</p>
    </div>

    <!-- Details -->
    <div class="vuln-section">
      <div class="vuln-section-title">Details</div>
      <div class="vuln-meta">
        <div class="vuln-meta-item">
          <span class="meta-label">Page:</span>
          <span class="meta-value">{{this.url}}</span>
        </div>
        <div class="vuln-meta-item">
          <span class="meta-label">Input field:</span>
          <span class="meta-value">{{this.param}}</span>
        </div>
        <div class="vuln-meta-item">
          <span class="meta-label">Risk level:</span>
          <span class="meta-value sev-{{this.severityClass}}">{{this.severity}}</span>
        </div>
        <div class="vuln-meta-item">
          <span class="meta-label">Test code:</span>
          <span class="meta-value"><span class="code-cell">{{this.payload}}</span></span>
        </div>
      </div>
    </div>

    <!-- How to fix it -->
    <div class="vuln-section">
      <div class="vuln-section-title">How to fix it</div>
      <div class="fix-box">
        <p>{{this.howToFix}}</p>
      </div>
    </div>
  </div>
  {{/each}}

  {{else}}

  <!-- No vulnerabilities -->
  <div class="no-vulns">
    <div class="checkmark">✅</div>
    <h3>No Security Issues Found</h3>
    <p>The scan did not detect any cross-site scripting vulnerabilities on this website.<br/>
    This doesn't guarantee the site is completely safe — consider running scans regularly and testing other vulnerability types.</p>
  </div>

  {{/if}}

  <div class="footer">
    Generated by RedSentinel v0.1.0 — {{generatedAt}}
  </div>
</body>
</html>
